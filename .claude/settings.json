{
  "$schema": "https://json.schema.anthropic.com/claude-code/settings.json",
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv run:*)",
      "Bash(uv add:*)",
      "Bash(uv lock:*)",
      "Bash(uv pip:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Edit(./examples/**)",
      "Edit(./eval/**)",
      "Edit(./docs/**)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Read(./.venv/**)",
      "Read(./**/.env)",
      "Read(./**/*.key)"
    ]
  }
}
